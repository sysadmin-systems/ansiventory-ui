# ==============================================================================
# Ansiventory UI — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores antes de iniciar.
# NUNCA comite o arquivo .env no controle de versão.
# ==============================================================================

# ------------------------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------------------------
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=ansiventory
POSTGRES_USER=ansiventory
POSTGRES_PASSWORD=changeme_strong_password

# Porta exposta no host (evite 5432 em produção para reduzir exposição)
POSTGRES_HOST_PORT=5432

# ------------------------------------------------------------------------------
# pgAdmin (opcional — descomente no compose para ativar)
# ------------------------------------------------------------------------------
PGADMIN_EMAIL=admin@ansiventory.local
PGADMIN_PASSWORD=changeme_pgadmin_password
PGADMIN_HOST_PORT=5050

# ------------------------------------------------------------------------------
# CloudBeaver (alternativa ao pgAdmin, baseada no DBeaver desktop)
# ------------------------------------------------------------------------------
CLOUDBEAVER_HOST_PORT=8978

# ------------------------------------------------------------------------------
# Backend (FastAPI)
# ------------------------------------------------------------------------------
BACKEND_HOST_PORT=8000

# ------------------------------------------------------------------------------
# Ambiente
# ------------------------------------------------------------------------------
# development | staging | production
APP_ENV=development

# ------------------------------------------------------------------------------
# Frontend URL (para CORS em produção)
# ------------------------------------------------------------------------------
FRONTEND_URL=https://ansiventory.bauhaus.systems

# ------------------------------------------------------------------------------
# Variáveis usadas pelo backend (FastAPI) — mapeamento automático
# O backend lê POSTGRES_* e APP_ENV das variáveis acima.
# Em produção, use também ENVIRONMENT=production se necessário.
# ------------------------------------------------------------------------------
